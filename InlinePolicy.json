{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3AccessPermissions",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::s3-stockprices",
        "arn:aws:s3:::s3-stockprices/*"
      ]
    }
  ]
}